 --------- EXCEL SERVICE ---------
class ExcelService {
    public void generateExcel(java.util.List<TransactionResponse> list) {
        System.out.println("Generating Excel...");
        for (TransactionResponse t : list) {
            System.out.println(t.id + "," + t.type + "," + t.amount + "," + t.purpose);
        }
    }
}

 --------- CONTROLLER ---------
class Controller {

    private UserService userService;
    private TransactionService transactionService;
    private FileService fileService;
    private ExcelService excelService;

    public Controller() {
        userService = new UserService(new InMemoryUserRepository());
        transactionService = new TransactionService(new InMemoryTransactionRepository());
        fileService = new FileService();
        excelService = new ExcelService();
    }

    // Signup API
    public User signup(SignupRequest req) {
        return userService.signup(req);
    }

    // Add Transaction API
    public TransactionResponse addTransaction(TransactionRequest req, String fileName) {
        String path = fileService.saveFile(fileName);
        return transactionService.addTransaction(req, path);
    }

    public java.util.List<TransactionResponse> getAll() {
        return transactionService.getAllTransactions();
    }

    public java.util.Map<String, Double> getSummary() {
        return transactionService.getExpenseSummary();
    }

    public void exportExcel() {
        excelService.generateExcel(transactionService.getAllTransactions());
    }
}

