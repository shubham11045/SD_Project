}

 --------- DTO LAYER ---------
class SignupRequest {
    public String username;
    public String email;
    public String password;
}

class TransactionRequest {
    public String type;
    public double amount;
    public String purpose;
    public java.time.LocalDate date;
}

class TransactionResponse {
    public Long id;
    public String type;
    public double amount;
    public String purpose;
    public String filePath;
    public String date;
}

 --------- REPOSITORY LAYER ---------
interface UserRepository {
    User save(User u);
}

class InMemoryUserRepository implements UserRepository {
    private java.util.List<User> users = new java.util.ArrayList<>();
    private Long idCounter = 1L;

    public User save(User u) {
        u.id = idCounter++;
        users.add(u);
        return u;
    }
}

interface TransactionRepository {
    Transaction save(Transaction t);
    java.util.List<Transaction> findAll();
}

class InMemoryTransactionRepository implements TransactionRepository {
    private java.util.List<Transaction> db = new java.util.ArrayList<>();
    private Long idCounter = 1L;

    public Transaction save(Transaction t) {
        t.id = idCounter++;
        db.add(t);
        return t;
    }

    public java.util.List<Transaction> findAll() {
        return db;
    }
}

--------- SERVICE LAYER ---------
class UserService {
    private UserRepository repo;

    public UserService(UserRepository repo) {
        this.repo = repo;
    }

    public User signup(SignupRequest req) {
        User u = new User();
        u.username = req.username;
        u.email = req.email;
        u.password = req.password; // (in real app -> encrypt it)
        return repo.save(u);
    }
}

class TransactionService {

    private TransactionRepository repo;

    public TransactionService(TransactionRepository repo) {
        this.repo = repo;
    }

    public TransactionResponse addTransaction(TransactionRequest req, String filePath) {
        Transaction t = new Transaction();
        t.type = req.type;
        t.amount = req.amount;
        t.purpose = req.purpose;
        t.filePath = filePath;
        t.date = req.date;

        Transaction saved = repo.save(t);
        return mapToResponse(saved);
    }

    public java.util.List<TransactionResponse> getAllTransactions() {
        java.util.List<Transaction> list = repo.findAll();
        java.util.List<TransactionResponse> res = new java.util.ArrayList<>();
        for (Transaction t : list) {
            res.add(mapToResponse(t));
        }
        return res;
    }

    private TransactionResponse mapToResponse(Transaction t) {
        TransactionResponse r = new TransactionResponse();
        r.id = t.id;
        r.type = t.type;
        r.amount = t.amount;
        r.purpose = t.purpose;
        r.filePath = t.filePath;
        r.date = t.date.toString();
        return r;
    }

     Pie Chart Data
    public java.util.Map<String, Double> getExpenseSummary() {
        java.util.List<Transaction> list = repo.findAll();
        java.util.Map<String, Double> map = new java.util.HashMap<>();

        for (Transaction t : list) {
            if (t.type.equals("EXPENSE")) {
                map.put(t.purpose,
                        map.getOrDefault(t.purpose, 0.0) + t.amount);
            }
        }
        return map;
    }
}

 --------- FILE SERVICE ---------
class FileService {
